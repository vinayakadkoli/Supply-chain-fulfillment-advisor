{
  "name": "supply-chain-fulfillment-advisor-cap",
  "version": "1.0.0",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/cds-dk": "^9.9.1"
  },
  "devDependencies": {
    "@cap-js/cds-test": "^1.0.1",
    "@cap-js/sqlite": "^2.4",
    "@jest/globals": "^30.4.1",
    "jest": "^30.4.2"
  },
  "scripts": {
    "start": "cds-serve",
    "dev:cap": "cds watch",
    "dev:ui": "npm run dev --workspace=ui",
    "build": "npm run build --workspace=ui && cds build --production",
    "preview": "npm run build --workspace=ui && cds watch",
    "test": "jest --testTimeout=30000",
    "custom_build": "sh custom_build.sh"
  },
  "private": true,
  "cds": {
    "requires": {
      "auth": "dummy",
      "db": {
        "kind": "hana"
      }
    },
    "build": {
      "target": "gen"
    }
  },
  "workspaces": [
    "ui"
  ]
}
